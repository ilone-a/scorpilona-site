---
interface Props {
    title: string;
    subtitle?: string;
    image: string;
}

const { title, subtitle, image } = Astro.props;
---

<section class="hero">

    <img src={image} alt="" class="hero-image">

    <div class="hero-overlay">
        <h1>{title}</h1>

        {subtitle && <p>{subtitle}</p>}
    </div>

</section>

<style>
.hero {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;

    min-height: 450px;
    overflow: hidden;
}

.hero-image {
    position: absolute;
    inset: 0;

    width: 100%;
    height: 100%;

    object-fit: cover;
    opacity: .5;
}

.hero-overlay {
    position: relative;
    z-index: 1;

    text-align: center;
}

.hero h1 {
    margin: 0;
}

.hero p {
    margin-top: .5rem;
    text-transform: uppercase;
    letter-spacing: .15em;
}
</style>